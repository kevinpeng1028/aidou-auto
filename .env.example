NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

BRAND_NAME=爱豆加油站
AUTO_PUBLISH=false
DATABASE_PATH=storage/app.sqlite

AUTO_GENERATE_DAILY_CANDIDATES=false
AUTO_GENERATE_WECHAT_DRAFT=false
AUTO_PUBLISH_LOW_RISK=false
ALLOW_MEDIUM_RISK_DRAFT=true
ALLOW_HIGH_RISK_DRAFT=false
AUTO_PUBLISH_MAX_PER_DAY=1
AUTO_DRAFT_MAX_PER_DAY=3

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

SEARCH_PROVIDER=mock
SEARCH_API_KEY=
SEARCH_REGION=KR
SEARCH_LANGUAGE=ko,en
KOREAN_MEDIA_SOURCE_MODE=broad
MAX_SEARCH_QUERIES_PER_RUN=40
MAX_SOURCE_URLS_PER_RUN=100
MAX_SOURCE_PACKAGES_PER_RUN=30
MAX_SEARCH_LEADS_PER_RUN=80
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS_PER_QUERY=5
TAVILY_INCLUDE_ANSWER=false
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_INCLUDE_IMAGES=false
TAVILY_TIMEOUT_MS=15000
GOOGLE_CSE_ID=

# WeChat draft creation credentials. Keep real values only in local .env.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ACCOUNT_NAME=爱豆加油站
WECHAT_DRAFT_MODE=true
WECHAT_ENABLE_PUBLISH=false
