<%- include('../partials/header', { title, user, brandName, autoPublish }) %>
<section class="heading-row">
  <div>
    <h1><%= article.title %></h1>
    <p class="muted">关键词：<%= article.keyword || '-' %> · 状态：<%= article.status %> · 更新时间：<%= article.updated_at %></p>
  </div>
  <div class="toolbar">
    <a class="button ghost" href="/articles/<%= article.id %>/edit">编辑</a>
    <a class="button ghost" href="/articles/<%= article.id %>/wechat-preview">预览微信排版</a>
    <form method="post" action="/articles/<%= article.id %>/audit"><button class="button ghost" type="submit">重新审核</button></form>
    <form method="post" action="/articles/<%= article.id %>/export"><button class="button primary" type="submit">导出 ZIP</button></form>
    <form method="post" action="/articles/<%= article.id %>/wechat-draft">
      <button class="button primary" type="submit" onclick="return confirm('只会创建微信公众号草稿，不会发布。继续？')">生成微信公众号草稿</button>
    </form>
  </div>
</section>

<% if (skippedNotice) { %>
  <section class="panel">
    <h2>该素材已跳过</h2>
    <p><strong><%= skippedNotice %></strong></p>
    <p class="muted">处理原因：<%= materialReason || '未记录原因，请检查日志' %></p>
  </section>
<% } %>

<% if (wechatDraftResult) { %>
  <section class="panel">
    <h2>微信草稿创建成功</h2>
    <dl class="status-list">
      <dt>cover_image_id</dt><dd><%= wechatDraftResult.coverImageId || '-' %></dd>
      <dt>cover local_path</dt><dd><%= wechatDraftResult.coverLocalPath || '-' %></dd>
      <dt>wechat thumb_media_id</dt><dd><strong><%= wechatDraftResult.thumbMediaId || '-' %></strong></dd>
      <dt>draft media_id</dt><dd><strong><%= wechatDraftResult.mediaId %></strong></dd>
      <dt>使用模板</dt><dd><%= wechatDraftResult.templateName || '默认模板' %></dd>
      <dt>正文图片数量</dt><dd><%= wechatDraftResult.inlineImageCount ?? 0 %></dd>
      <dt>图文一致性</dt><dd><%= wechatDraftResult.consistencyPassed ? '通过' : '需人工检查' %><% if (wechatDraftResult.consistencyScore !== undefined) { %>（<%= wechatDraftResult.consistencyScore %> 分）<% } %></dd>
    </dl>
    <% if (wechatDraftResult.note) { %><p class="muted"><%= wechatDraftResult.note %></p><% } %>
    <p class="muted">创建时间：<%= wechatDraftResult.createdAt %></p>
  </section>
<% } %>

<% if (wechatDraftError) { %>
  <section class="panel">
    <h2>微信接口错误</h2>
    <p>errcode：<strong><%= wechatDraftError.errcode %></strong></p>
    <p>errmsg：<%= wechatDraftError.errmsg %></p>
    <p class="muted">时间：<%= wechatDraftError.createdAt %></p>
    <p>建议检查项：<%= wechatDraftError.suggestions.join(' / ') %></p>
  </section>
<% } %>

<section class="panel">
  <h2>图片关联状态</h2>
  <h3>当前封面图</h3>
  <% if (coverImage) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>预览</th><th>id</th><th>usage_scene</th><th>local_path</th></tr></thead>
        <tbody>
          <tr>
            <td>
              <% if (coverImage.local_path) { %>
                <img src="/<%= coverImage.local_path %>" alt="封面图预览" style="width:120px;height:90px;object-fit:cover;border-radius:6px;">
              <% } else { %>
                <span class="muted">无本地文件</span>
              <% } %>
            </td>
            <td><%= coverImage.id %></td>
            <td><%= coverImage.usage_scene %></td>
            <td><%= coverImage.local_path || '-' %></td>
          </tr>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <p class="muted">未关联封面图</p>
  <% } %>

  <h3>当前正文图列表</h3>
  <% if (inlineImages.length) { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>预览</th><th>id</th><th>usage_scene</th><th>local_path</th></tr></thead>
        <tbody>
        <% inlineImages.forEach((image) => { %>
          <tr>
            <td>
              <% if (image.local_path) { %>
                <img src="/<%= image.local_path %>" alt="正文图预览" style="width:120px;height:90px;object-fit:cover;border-radius:6px;">
              <% } else { %>
                <span class="muted">无本地文件</span>
              <% } %>
            </td>
            <td><%= image.id %></td>
            <td><%= image.usage_scene %></td>
            <td><%= image.local_path || '-' %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <p class="muted">当前没有正文图</p>
  <% } %>
</section>

<% if (dailyCandidate) { %>
  <section class="panel">
    <h2>每日候选来源与评分</h2>
    <dl class="status-list">
      <dt>candidate status</dt><dd><%= dailyCandidate.status %></dd>
      <dt>rank</dt><dd><%= dailyCandidate.rank %></dd>
      <dt>topic_keyword</dt><dd><%= dailyCandidate.topic_keyword || '-' %></dd>
      <dt>source_url</dt><dd><%= dailyCandidate.source_url || '-' %></dd>
      <dt>source_name</dt><dd><%= dailyCandidate.source_name || '-' %></dd>
      <dt>source_type</dt><dd><%= dailyCandidate.source_type || '-' %></dd>
      <dt>source_summary</dt><dd><%= dailyCandidate.source_summary || '-' %></dd>
      <dt>candidate_reason</dt><dd><%= dailyCandidate.candidate_reason || '-' %></dd>
      <dt>selected_reason</dt><dd><%= dailyCandidate.selected_reason || '-' %></dd>
      <dt>risk_notes</dt><dd><%= dailyCandidate.risk_notes || '-' %></dd>
      <dt>freshness_score</dt><dd><%= dailyCandidate.freshness_score %></dd>
      <dt>topic_heat_score</dt><dd><%= dailyCandidate.topic_heat_score %></dd>
      <dt>image_quality_score</dt><dd><%= dailyCandidate.image_quality_score %></dd>
      <dt>image_article_match_score</dt><dd><%= dailyCandidate.image_article_match_score %></dd>
      <dt>article_quality_score</dt><dd><%= dailyCandidate.article_quality_score %></dd>
      <dt>predicted_read_score</dt><dd><%= dailyCandidate.predicted_read_score %></dd>
      <dt>risk_score</dt><dd><%= dailyCandidate.risk_score %></dd>
      <dt>anti_ai_score</dt><dd><%= dailyCandidate.anti_ai_score %></dd>
      <dt>total_score</dt><dd><strong><%= dailyCandidate.total_score %></strong></dd>
    </dl>
  </section>
<% } %>

<section class="panel">
  <h2>完整风险面板</h2>
  <dl class="status-list">
    <dt>risk_level</dt><dd><%= article.risk_level || materialScores.risk_level || '-' %></dd>
    <dt>overall_risk_score</dt><dd><%= article.overall_risk_score ?? materialScores.overall_risk_score ?? '-' %></dd>
    <dt>source_risk_score</dt><dd><%= article.source_risk_score ?? materialScores.source_risk_score ?? '-' %></dd>
    <dt>image_copyright_risk_score</dt><dd><%= article.image_copyright_risk_score ?? materialScores.image_copyright_risk_score ?? '-' %></dd>
    <dt>article_rewrite_risk_score</dt><dd><%= article.article_rewrite_risk_score ?? materialScores.article_rewrite_risk_score ?? '-' %></dd>
    <dt>image_article_match_score</dt><dd><%= article.image_article_match_score ?? materialScores.image_article_match_score ?? '-' %></dd>
    <dt>watermark_risk_score</dt><dd><%= article.watermark_risk_score ?? materialScores.watermark_risk_score ?? '-' %></dd>
    <dt>platform_compliance_score</dt><dd><%= article.platform_compliance_score ?? materialScores.platform_compliance_score ?? '-' %></dd>
    <dt>source_risk_level</dt><dd><%= article.source_risk_level || materialScores.source_risk_level || '-' %></dd>
    <dt>source_policy_result</dt><dd><%= article.source_policy_result || materialScores.source_policy_result || '-' %></dd>
    <dt>copyright_notes</dt><dd><%= article.copyright_notes || materialScores.copyright_notes || '-' %></dd>
    <dt>auto_action_taken</dt><dd><%= article.auto_action_taken || materialScores.auto_action_taken || '-' %></dd>
    <dt>auto_action_reason</dt><dd><%= article.auto_action_reason || materialScores.auto_action_reason || '-' %></dd>
    <dt>wechat_draft_media_id</dt><dd><%= article.wechat_draft_media_id || '-' %></dd>
    <dt>wechat_publish_id</dt><dd><%= article.wechat_publish_id || '-' %></dd>
    <dt>published_at</dt><dd><%= article.published_at || '-' %></dd>
    <dt>auto_publish_reason</dt><dd><%= article.auto_publish_reason || '-' %></dd>
  </dl>
</section>

<section class="panel">
  <h2>素材评估信息</h2>
  <dl class="status-list">
    <dt>status</dt><dd><%= article.status %></dd>
    <dt>total_score</dt><dd><%= article.total_score ?? materialScores.total_score ?? '-' %></dd>
    <dt>topic_heat_score</dt><dd><%= article.topic_heat_score ?? materialScores.topic_heat_score ?? '-' %></dd>
    <dt>freshness_score</dt><dd><%= article.freshness_score ?? materialScores.freshness_score ?? '-' %></dd>
    <dt>image_quality_score</dt><dd><%= article.image_quality_score ?? materialScores.image_quality_score ?? '-' %></dd>
    <dt>image_relevance_score</dt><dd><%= article.image_relevance_score ?? materialScores.image_relevance_score ?? '-' %></dd>
    <dt>article_quality_score</dt><dd><%= article.article_quality_score ?? materialScores.article_quality_score ?? '-' %></dd>
    <dt>predicted_read_score</dt><dd><%= article.predicted_read_score ?? materialScores.predicted_read_score ?? '-' %></dd>
    <dt>risk_score</dt><dd><%= materialScores.risk_score_dimension ?? article.risk_score ?? '-' %></dd>
    <dt>anti_ai_score</dt><dd><%= article.anti_ai_score ?? materialScores.anti_ai_score ?? '-' %></dd>
    <dt>risk_level</dt><dd><%= article.risk_level || '-' %></dd>
    <dt>selected_reason</dt><dd><%= materialScores.selected_reason || article.selected_reason || '-' %></dd>
    <dt>risk_notes</dt><dd><%= materialScores.risk_notes || '-' %></dd>
    <dt>image_quality_notes</dt><dd><%= materialScores.image_quality_notes || '-' %></dd>
    <dt>duplicate_check_result</dt><dd><%= materialScores.duplicate_check_result || '-' %></dd>
    <dt>source_urls</dt><dd><%= (materialScores.source_urls || [article.source_url]).filter(Boolean).join(' / ') || '-' %></dd>
    <dt>cover_image_id</dt><dd><%= article.cover_image_id || '-' %></dd>
    <dt>inline_image_ids</dt><dd><%= article.inline_image_ids || '[]' %></dd>
    <dt>wechat_template_id</dt><dd><%= article.wechat_template_id || article.template_id || '默认模板' %></dd>
    <dt>wechat_draft_media_id</dt><dd><%= article.wechat_draft_media_id || '-' %></dd>
    <dt>wechat_thumb_media_id</dt><dd><%= article.wechat_thumb_media_id || '-' %></dd>
    <dt>draft_created_at</dt><dd><%= article.draft_created_at || '-' %></dd>
    <dt>cover_image</dt><dd><%= coverImage?.local_path || '-' %></dd>
    <dt>inline_images</dt><dd><%= inlineImages.map((image) => image.local_path || image.url).filter(Boolean).join(' / ') || '-' %></dd>
    <dt>可生成草稿</dt><dd><%= coverImage?.local_path ? '是' : '否，缺少封面图' %></dd>
  </dl>
</section>

<section class="grid two">
  <article class="panel article-preview">
    <h2>Markdown</h2>
    <pre><%= article.markdown %></pre>
  </article>
  <aside class="panel">
    <h2>风险报告</h2>
    <p>风险分：<span class="pill <%= article.risk_score >= 85 ? 'ok' : 'danger' %>"><%= article.risk_score %></span></p>
    <pre><%= article.risk_report || '暂无审核报告' %></pre>
  </aside>
</section>

<form method="post" action="/articles/<%= article.id %>/delete" class="danger-zone">
  <button class="button danger" type="submit" onclick="return confirm('确定删除这篇文章？')">删除文章</button>
</form>
<%- include('../partials/footer') %>
