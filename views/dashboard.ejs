<%- include('partials/header', { title, user, brandName, autoPublish }) %>
<section class="heading-row">
  <div>
    <h1>Dashboard</h1>
    <p class="muted"><%= today %> 今日运营状态</p>
  </div>
  <div class="toolbar">
    <span class="pill <%= system.autoPublish ? 'danger' : 'ok' %>">AUTO_PUBLISH=<%= system.autoPublish %></span>
    <span class="pill ok">自动发布接口未启用</span>
    <% if (search.provider === 'mock') { %><span class="pill">SEARCH_PROVIDER=mock</span><% } %>
    <% if (search.provider === 'tavily') { %><span class="pill ok">SEARCH_PROVIDER=tavily</span><% } %>
    <form method="post" action="/daily-candidates/generate">
      <button class="button primary" type="submit">生成今日 10 篇候选文章</button>
    </form>
    <a class="button ghost" href="/candidates">查看候选池</a>
  </div>
</section>

<% if (dailyCandidateResult) { %>
  <section class="panel">
    <h2>今日候选生成完成</h2>
    <dl class="status-list">
      <dt>SEARCH_PROVIDER</dt><dd><%= dailyCandidateResult.searchProvider || search.provider %></dd>
      <dt>本次搜索 query 数量</dt><dd><%= dailyCandidateResult.searchQueryCount ?? '-' %></dd>
      <dt>Tavily 返回 URL 数量</dt><dd><%= dailyCandidateResult.tavilyReturnedUrlCount ?? '-' %></dd>
      <dt>去重过滤后 URL 数量</dt><dd><%= dailyCandidateResult.dedupedUrlCount ?? '-' %></dd>
      <dt>搜索 URL 数量</dt><dd><%= dailyCandidateResult.searchedUrlCount ?? '-' %></dd>
      <dt>skipped 数量</dt><dd><%= dailyCandidateResult.skippedCount ?? 0 %></dd>
      <dt>完整 source package 数量</dt><dd><%= dailyCandidateResult.completeSourcePackageCount ?? '-' %></dd>
      <dt>已导入 source package 数量</dt><dd><%= dailyCandidateResult.importedPackageCount ?? '-' %></dd>
      <dt>已保存图片数量</dt><dd><%= dailyCandidateResult.downloadedImageCount ?? '-' %></dd>
      <dt>封面图包数量</dt><dd><%= dailyCandidateResult.coverImageCount ?? '-' %></dd>
      <dt>正文图包数量</dt><dd><%= dailyCandidateResult.inlineImagePackageCount ?? '-' %></dd>
      <dt>同源校验通过数量</dt><dd><%= dailyCandidateResult.sameSourcePassedCount ?? '-' %></dd>
      <dt>今日候选生成数量</dt><dd><%= dailyCandidateResult.generatedCount %></dd>
      <dt>已评分数量</dt><dd><%= dailyCandidateResult.scoredCount %></dd>
      <dt>低风险数量</dt><dd><%= dailyCandidateResult.lowRiskCount %></dd>
      <dt>中风险数量</dt><dd><%= dailyCandidateResult.mediumRiskCount %></dd>
      <dt>高风险数量</dt><dd><%= dailyCandidateResult.highRiskCount %></dd>
      <dt>selected_candidate 标题</dt><dd><%= dailyCandidateResult.selectedCandidate?.title || '-' %></dd>
      <dt>selected_candidate source_url</dt><dd><%= dailyCandidateResult.selectedCandidate?.source_url || '-' %></dd>
      <dt>selected_candidate source_name</dt><dd><%= dailyCandidateResult.selectedCandidate?.source_name || '-' %></dd>
      <dt>selected_candidate cover_image_id</dt><dd><%= dailyCandidateResult.selectedCandidate?.cover_image_id || '-' %></dd>
      <dt>selected_candidate inline_image_ids</dt><dd><%= JSON.stringify(dailyCandidateResult.selectedCandidate?.inline_image_ids || []) %></dd>
      <dt>selected_candidate total_score</dt><dd><%= dailyCandidateResult.selectedCandidate?.total_score ?? '-' %></dd>
      <dt>selected_candidate risk_level</dt><dd><%= dailyCandidateResult.selectedCandidate?.risk_level || '-' %></dd>
      <dt>是否 mock 模式</dt><dd><%= dailyCandidateResult.mockMode ? '是，mock source package 不依赖外部图片 URL' : '否，真实搜索导入' %></dd>
      <dt>是否已录入素材库</dt><dd><%= dailyCandidateResult.savedToArticles ? '是' : '否' %></dd>
      <dt>是否已生成微信草稿</dt><dd><%= dailyCandidateResult.wechatDraftCreated ? '是' : '否，本次 dry-run 不创建真实草稿' %></dd>
      <dt>是否已发布</dt><dd><%= dailyCandidateResult.published ? '是' : '否，本次 no-publish' %></dd>
    </dl>
    <% if (dailyCandidateResult.skippedReasons && dailyCandidateResult.skippedReasons.length) { %>
      <h3>skipped reasons</h3>
      <ul>
        <% dailyCandidateResult.skippedReasons.forEach((item) => { %>
          <li><%= item.reason %> <small><%= item.url || item.query || '' %></small></li>
        <% }) %>
      </ul>
    <% } %>
  </section>
<% } %>

<% if (dailyCandidateError) { %>
  <section class="panel">
    <h2>今日候选生成失败</h2>
    <p><%= dailyCandidateError.message %></p>
    <p class="muted"><%= dailyCandidateError.code %></p>
  </section>
<% } %>

<% if (dailyMaterialResult) { %>
  <section class="panel">
    <h2>今日素材生成完成</h2>
    <p>创建：<strong><%= dailyMaterialResult.created %></strong> · ready：<strong><%= dailyMaterialResult.ready %></strong> · auto_draft_only：<strong><%= dailyMaterialResult.autoDraftOnly || 0 %></strong> · review：<strong><%= dailyMaterialResult.review %></strong> · skipped：<strong><%= dailyMaterialResult.skipped %></strong> · rejected：<strong><%= dailyMaterialResult.rejected %></strong></p>
  </section>
<% } %>

<% if (dailyMaterialError) { %>
  <section class="panel">
    <h2>今日素材生成失败</h2>
    <p><%= dailyMaterialError.message %></p>
    <% if (dailyMaterialError.code === 'SEARCH_NOT_CONFIGURED') { %>
      <p class="muted">搜索服务未配置。请配置 SEARCH_PROVIDER / SEARCH_API_KEY，或使用 SEARCH_PROVIDER=mock 测试流程。</p>
    <% } %>
  </section>
<% } %>

<section class="grid four">
  <div class="metric"><span>今日候选</span><strong><%= stats.candidatesToday %></strong></div>
  <div class="metric"><span>今日首选候选</span><strong><%= stats.selectedCandidateToday %></strong></div>
  <div class="metric"><span>完整图文包</span><strong><%= stats.completeSourcePackagesToday %></strong></div>
  <div class="metric"><span>自动发布阻断</span><strong><%= stats.todayPublishBlocked %></strong></div>
</section>

<section class="grid four">
  <div class="metric"><span>文章总数</span><strong><%= stats.articles %></strong></div>
  <div class="metric"><span>今日 source package</span><strong><%= stats.sourcePackagesToday %></strong></div>
  <div class="metric"><span>今日导入文章</span><strong><%= stats.todayArticles %></strong></div>
  <div class="metric"><span>今日本地图片</span><strong><%= stats.downloadedImagesToday %></strong></div>
</section>

<section class="panel">
  <h2>搜索配置</h2>
  <dl class="status-list">
    <dt>SEARCH_PROVIDER</dt><dd><%= search.provider %></dd>
    <dt>SEARCH_REGION</dt><dd><%= search.region %></dd>
    <dt>SEARCH_LANGUAGE</dt><dd><%= search.language %></dd>
    <dt>KOREAN_MEDIA_SOURCE_MODE</dt><dd><%= search.koreanMediaSourceMode %></dd>
    <dt>MAX_SEARCH_QUERIES_PER_RUN</dt><dd><%= search.maxSearchQueriesPerRun %></dd>
    <dt>MAX_SOURCE_URLS_PER_RUN</dt><dd><%= search.maxSourceUrlsPerRun %></dd>
    <dt>MAX_SOURCE_PACKAGES_PER_RUN</dt><dd><%= search.maxSourcePackagesPerRun %></dd>
    <dt>TAVILY_SEARCH_DEPTH</dt><dd><%= search.tavily.searchDepth %></dd>
    <dt>TAVILY_MAX_RESULTS_PER_QUERY</dt><dd><%= search.tavily.maxResultsPerQuery %></dd>
  </dl>
  <% if (search.provider === 'mock') { %>
    <p class="muted">当前为 mock 流程测试，不是真实韩国媒体搜索结果。</p>
  <% } %>
  <% if (search.provider === 'tavily') { %>
    <p class="muted">当前为 Tavily 真实搜索模式。</p>
  <% } %>
</section>

<section class="panel">
  <h2>自动化配置</h2>
  <dl class="status-list">
    <dt>AUTO_GENERATE_DAILY_CANDIDATES</dt><dd><%= automation.autoGenerateDailyCandidates %></dd>
    <dt>AUTO_GENERATE_WECHAT_DRAFT</dt><dd><%= automation.autoGenerateWechatDraft %></dd>
    <dt>AUTO_PUBLISH_LOW_RISK</dt><dd><%= automation.autoPublishLowRisk %>（当前项目策略仍阻断自动发布）</dd>
    <dt>ALLOW_MEDIUM_RISK_DRAFT</dt><dd><%= automation.allowMediumRiskDraft %></dd>
    <dt>ALLOW_HIGH_RISK_DRAFT</dt><dd><%= automation.allowHighRiskDraft %></dd>
    <dt>AUTO_PUBLISH_MAX_PER_DAY</dt><dd><%= automation.autoPublishMaxPerDay %></dd>
    <dt>AUTO_DRAFT_MAX_PER_DAY</dt><dd><%= automation.autoDraftMaxPerDay %></dd>
  </dl>
</section>

<section class="panel">
  <h2>系统状态</h2>
  <dl class="status-list">
    <dt>Node.js</dt><dd><%= system.node %></dd>
    <dt>运行环境</dt><dd><%= system.env %></dd>
    <dt>SQLite</dt><dd><%= system.database %></dd>
    <dt>OpenAI</dt><dd><%= system.openai %></dd>
    <dt>今日选题</dt><dd><%= stats.todayTopics %> 个</dd>
  </dl>
</section>

<section class="panel">
  <h2>今日任务状态</h2>
  <% if (!logs.length) { %>
    <p class="muted">暂无任务记录。</p>
  <% } %>
  <div class="table-wrap">
    <table>
      <thead><tr><th>时间</th><th>任务</th><th>状态</th><th>说明</th></tr></thead>
      <tbody>
      <% logs.forEach((log) => { %>
        <tr>
          <td><%= log.created_at %></td>
          <td><%= log.task_name %></td>
          <td><span class="pill <%= log.status === 'success' || log.status === 'ok' ? 'ok' : 'danger' %>"><%= log.status %></span></td>
          <td><%= log.message %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
