<%- include('../partials/header', { title, user, brandName, autoPublish }) %>
<section class="heading-row">
  <div>
    <h1>每日候选文章</h1>
    <p class="muted">今日 10 篇候选、source package、同源图片、评分、风险等级和首选发布候选。</p>
  </div>
  <form method="post" action="/candidates/generate">
    <button class="button primary" type="submit">生成今日 10 篇候选文章</button>
  </form>
</section>

<% if (result) { %>
  <section class="panel">
    <h2>候选生成完成</h2>
    <dl class="status-list">
      <dt>搜索 URL 数量</dt><dd><%= result.searchedUrlCount ?? '-' %></dd>
      <dt>已导入 source package 数量</dt><dd><%= result.importedPackageCount ?? '-' %></dd>
      <dt>完整 source package 数量</dt><dd><%= result.completeSourcePackageCount ?? '-' %></dd>
      <dt>已保存图片数量</dt><dd><%= result.downloadedImageCount ?? '-' %></dd>
      <dt>封面图包数量</dt><dd><%= result.coverImageCount ?? '-' %></dd>
      <dt>正文图包数量</dt><dd><%= result.inlineImagePackageCount ?? '-' %></dd>
      <dt>同源校验通过数量</dt><dd><%= result.sameSourcePassedCount ?? '-' %></dd>
      <dt>今日候选生成数量</dt><dd><%= result.generatedCount %></dd>
      <dt>已评分数量</dt><dd><%= result.scoredCount %></dd>
      <dt>低风险数量</dt><dd><%= result.lowRiskCount %></dd>
      <dt>中风险数量</dt><dd><%= result.mediumRiskCount %></dd>
      <dt>高风险数量</dt><dd><%= result.highRiskCount %></dd>
      <dt>selected_candidate 标题</dt><dd><%= result.selectedCandidate?.title || '-' %></dd>
      <dt>selected_candidate source_package_id</dt><dd><%= result.selectedCandidate?.source_package_id || '-' %></dd>
      <dt>selected_candidate cover_image_id</dt><dd><%= result.selectedCandidate?.cover_image_id || '-' %></dd>
      <dt>selected_candidate inline_image_ids</dt><dd><%= JSON.stringify(result.selectedCandidate?.inline_image_ids || []) %></dd>
      <dt>selected_candidate total_score</dt><dd><%= result.selectedCandidate?.total_score ?? '-' %></dd>
      <dt>selected_candidate risk_level</dt><dd><%= result.selectedCandidate?.risk_level || '-' %></dd>
      <dt>是否 mock 模式</dt><dd><%= result.mockMode ? '是，mock source package 不依赖外部图片 URL' : '否，真实搜索导入' %></dd>
      <dt>是否已录入素材库</dt><dd><%= result.savedToArticles ? '是' : '否' %></dd>
      <dt>是否已录入图片库</dt><dd><%= result.savedToImages ? '是' : '否' %></dd>
      <dt>是否已生成微信草稿</dt><dd><%= result.wechatDraftCreated ? '是' : '否，本次 dry-run 不创建真实草稿' %></dd>
      <dt>是否已发布</dt><dd><%= result.published ? '是' : '否，本次 no-publish' %></dd>
    </dl>
  </section>
<% } %>

<% if (error) { %>
  <section class="panel">
    <h2>候选生成失败</h2>
    <p><%= error.message %></p>
    <p class="muted"><%= error.code %></p>
  </section>
<% } %>

<section class="grid four">
  <div class="metric"><span>今日候选</span><strong><%= summary.generatedCount %></strong></div>
  <div class="metric"><span>完整图文包</span><strong><%= summary.completeSourcePackageCount %></strong></div>
  <div class="metric"><span>已保存图片</span><strong><%= summary.downloadedImageCount %></strong></div>
  <div class="metric"><span>高风险</span><strong><%= summary.highRiskCount %></strong></div>
</section>

<% if (summary.selectedCandidate) { %>
  <section class="panel">
    <h2>selected_candidate 绑定状态</h2>
    <dl class="status-list">
      <dt>article_id</dt><dd><%= summary.selectedCandidate.article_id || '-' %></dd>
      <dt>source_package_id</dt><dd><%= summary.selectedCandidate.source_package_id || '-' %></dd>
      <dt>cover_image_id</dt><dd><%= summary.selectedCandidate.cover_image_id || '未关联封面图' %></dd>
      <dt>inline_image_ids</dt><dd><%= JSON.stringify(summary.selectedCandidate.inline_image_ids || []) %></dd>
    </dl>
  </section>
<% } %>

<section class="panel">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>排名</th>
          <th>标题</th>
          <th>source_package</th>
          <th>封面</th>
          <th>正文图</th>
          <th>图片数</th>
          <th>idol_name</th>
          <th>group_name</th>
          <th>来源</th>
          <th>发布时间</th>
          <th>total</th>
          <th>image</th>
          <th>match</th>
          <th>risk_level</th>
          <th>status</th>
          <th>candidate_reason</th>
          <th>selected_reason</th>
          <th>risk_notes</th>
        </tr>
      </thead>
      <tbody>
      <% rows.forEach((row) => { %>
        <tr>
          <td><%= row.rank %></td>
          <td>
            <% if (row.article_id) { %><a href="/articles/<%= row.article_id %>"><%= row.title %></a><% } else { %><%= row.title %><% } %>
          </td>
          <td><%= row.source_package_id || '-' %></td>
          <td><%= row.cover_image_id || '-' %></td>
          <td><%= row.inline_image_ids || '[]' %></td>
          <td><%= row.usable_image_count || 0 %>/<%= row.image_count || 0 %></td>
          <td><%= row.idol_name || '-' %></td>
          <td><%= row.group_name || '-' %></td>
          <td><%= row.source_name || '-' %><br><small><%= row.source_url || '-' %></small></td>
          <td><%= row.source_published_at || '-' %></td>
          <td><strong><%= row.total_score %></strong></td>
          <td><%= row.image_quality_score %></td>
          <td><%= row.image_article_match_score %></td>
          <td><span class="pill <%= row.risk_level === 'low' ? 'ok' : (row.risk_level === 'high' ? 'danger' : '') %>"><%= row.risk_level %></span></td>
          <td><%= row.status %></td>
          <td><%= row.candidate_reason || '-' %></td>
          <td><%= row.selected_reason || '-' %></td>
          <td><%= row.risk_notes || '-' %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/footer') %>
