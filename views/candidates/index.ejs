<%- include('../partials/header', { title, user, brandName, autoPublish }) %>
<section class="heading-row">
  <div>
    <h1>每日候选文章</h1>
    <p class="muted">先保存搜索线索，再做来源风险、图片质量和人工审核分级。</p>
  </div>
  <form method="post" action="/candidates/generate">
    <button class="button primary" type="submit"><%= taskRunning ? '候选生成任务运行中' : '生成今日候选题材线索' %></button>
  </form>
</section>

<% if (taskRunning) { %>
  <section class="panel">
    <h2>候选生成任务正在运行</h2>
    <p>候选生成任务正在运行，请不要重复点击。稍后刷新查看结果。</p>
  </section>
<% } %>

<section class="panel">
  <h2>测试 Tavily 搜索</h2>
  <form method="post" action="/candidates/test-tavily" class="stacked-form">
    <label>query
      <input type="text" name="query" value="K-pop idol latest photos" placeholder="K-pop idol latest photos">
    </label>
    <label>max_results
      <input type="number" name="max_results" value="5" min="1" max="10">
    </label>
    <button class="button" type="submit">测试 Tavily 搜索</button>
  </form>
  <p class="muted">只测试搜索可用性，不生成文章，不下载图片，不创建微信草稿，不发布。</p>
</section>

<% if (tavilyTestResult) { %>
  <section class="panel">
    <h2>Tavily 搜索测试结果</h2>
    <dl class="status-list">
      <dt>API 是否可用</dt><dd><%= tavilyTestResult.available ? '是' : '否' %></dd>
      <dt>query</dt><dd><%= tavilyTestResult.query %></dd>
      <dt>返回结果数量</dt><dd><%= tavilyTestResult.result_count %></dd>
    </dl>
    <div class="table-wrap">
      <table>
        <thead><tr><th>title</th><th>url</th><th>host</th><th>registry</th><th>trust</th><th>risk</th><th>review</th><th>可导入</th><th>拒绝原因</th></tr></thead>
        <tbody>
        <% tavilyTestResult.results.forEach((item) => { %>
          <tr>
            <td><%= item.title || '-' %></td>
            <td><small><%= item.url || '-' %></small></td>
            <td><%= item.host || '-' %></td>
            <td><%= item.in_registry ? '是' : '否' %></td>
            <td><%= item.source_trust_level || '-' %></td>
            <td><%= item.risk_level || '-' %></td>
            <td><%= item.review_required ? '是' : '否' %></td>
            <td><%= item.can_import_source_package ? '是' : '否' %></td>
            <td><%= item.reject_reason || '-' %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </section>
<% } %>

<% if (tavilyTestError) { %>
  <section class="panel">
    <h2>Tavily 搜索测试失败</h2>
    <p><%= tavilyTestError.message %></p>
    <p class="muted"><%= tavilyTestError.code %></p>
  </section>
<% } %>

<% if (result) { %>
  <section class="panel">
    <h2><%= result.partialSuccess ? '候选生成部分完成' : (result.started ? '候选生成任务已开始' : '候选生成完成') %></h2>
    <% if (result.message) { %><p><%= result.message %></p><% } %>
    <dl class="status-list">
      <dt>SEARCH_PROVIDER</dt><dd><%= result.searchProvider || '-' %></dd>
      <dt>搜索 query 数量</dt><dd><%= result.searchQueryCount ?? '-' %></dd>
      <dt>Tavily raw URL</dt><dd><%= result.tavilyReturnedUrlCount ?? '-' %></dd>
      <dt>去重后 URL</dt><dd><%= result.dedupedUrlCount ?? '-' %></dd>
      <dt>search leads</dt><dd><%= result.searchLeadCount ?? '-' %></dd>
      <dt>source package 导入</dt><dd><%= result.importedPackageCount ?? '-' %></dd>
      <dt>可生成文章候选</dt><dd><%= result.readyToGenerateArticleCount ?? 0 %></dd>
      <dt>文字候选</dt><dd><%= result.textOnlyCandidateCount ?? 0 %></dd>
      <dt>图片不足</dt><dd><%= result.imageInsufficientCount ?? 0 %></dd>
      <dt>review</dt><dd><%= result.reviewCount ?? 0 %></dd>
      <dt>高风险</dt><dd><%= result.highRiskCount ?? 0 %></dd>
      <dt>导入失败</dt><dd><%= result.importFailedCount ?? 0 %></dd>
      <dt>图片线索</dt><dd><%= result.imageFoundCount ?? '-' %></dd>
      <dt>图片入库</dt><dd><%= result.imageImportedCount ?? result.downloadedImageCount ?? '-' %></dd>
      <dt>selected_candidate</dt><dd><%= result.selectedCandidate?.title || '-' %></dd>
      <dt>是否已发布</dt><dd><%= result.published ? '是' : '否，本次 no-publish' %></dd>
    </dl>
    <% if (result.skippedReasons && result.skippedReasons.length) { %>
      <h3>reasons</h3>
      <ul>
        <% result.skippedReasons.forEach((item) => { %>
          <li><%= item.reason %> <small><%= item.url || item.query || '' %></small></li>
        <% }) %>
      </ul>
    <% } %>
  </section>
<% } %>

<% if (error) { %>
  <section class="panel">
    <h2>候选生成失败</h2>
    <p><%= error.message %></p>
    <p class="muted"><%= error.code %></p>
  </section>
<% } %>

<section class="grid four">
  <div class="metric"><span>全部线索</span><strong><%= summary.generatedCount %></strong></div>
  <div class="metric"><span>可生成文章</span><strong><%= summary.readyToGenerateArticleCount %></strong></div>
  <div class="metric"><span>待审核</span><strong><%= summary.reviewCount %></strong></div>
  <div class="metric"><span>文字候选</span><strong><%= summary.textOnlyCandidateCount %></strong></div>
</section>

<section class="grid four">
  <div class="metric"><span>图片不足</span><strong><%= summary.imageInsufficientCount %></strong></div>
  <div class="metric"><span>未知风险</span><strong><%= summary.unknownRiskCount %></strong></div>
  <div class="metric"><span>高风险</span><strong><%= summary.highRiskCount %></strong></div>
  <div class="metric"><span>导入失败</span><strong><%= summary.importFailedCount %></strong></div>
</section>

<% const sections = [
  ['可生成文章候选', rowGroups.readyToGenerate],
  ['图片不足候选', rowGroups.imageInsufficient],
  ['文字候选', rowGroups.textOnly],
  ['待人工审核线索', rowGroups.reviewRequired],
  ['高风险线索', rowGroups.highRisk],
  ['导入失败线索', rowGroups.importFailed]
]; %>

<% sections.forEach(([sectionTitle, sectionRows]) => { %>
  <section class="panel">
    <h2><%= sectionTitle %>（<%= sectionRows.length %>）</h2>
    <% if (!sectionRows.length) { %>
      <p class="muted">暂无记录。</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>标题</th><th>来源</th><th>trust</th><th>risk</th><th>status</th><th>import</th><th>图片</th><th>说明</th><th>操作</th>
            </tr>
          </thead>
          <tbody>
          <% sectionRows.forEach((row) => { %>
            <tr>
              <td><% if (row.article_id) { %><a href="/articles/<%= row.article_id %>"><%= row.title %></a><% } else { %><%= row.title %><% } %><br><small><%= row.source_discovery_type || '-' %></small></td>
              <td><%= row.source_name || '-' %><br><small><%= row.source_url || '-' %></small></td>
              <td><%= row.source_trust_level || '-' %></td>
              <td><span class="pill <%= row.risk_level === 'low' ? 'ok' : (row.risk_level === 'high' ? 'danger' : '') %>"><%= row.risk_level || '-' %></span></td>
              <td><%= row.status %><br><small>review=<%= row.review_required ? 'yes' : 'no' %></small></td>
              <td><%= row.import_status || '-' %><br><small><%= row.import_failed_reason || '' %></small></td>
              <td><%= row.usable_image_count || 0 %>/<%= row.image_count || 0 %><br><small>cover <%= row.cover_image_id || '-' %> · inline <%= row.inline_image_ids || '[]' %></small></td>
              <td><%= row.selected_reason || '-' %><br><small><%= row.risk_notes || '-' %></small></td>
              <td>
                <% if (row.source_url) { %><a class="button ghost" href="<%= row.source_url %>" target="_blank" rel="noopener noreferrer">打开来源</a><% } %>
                <% if (row.article_id) { %><a class="button ghost" href="/articles/<%= row.article_id %>">查看详情</a><% } else { %><button class="button ghost" type="button" disabled>查看详情</button><% } %>
                <% if (row.status === 'ready_to_generate_article') { %><button class="button" type="button" disabled>生成审核文章</button><% } %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
<% }) %>
<%- include('../partials/footer') %>
